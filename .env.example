# Copie ce fichier en .env.local (non versionné) et remplis les valeurs
# Tableau Supabase : Project Settings → API
VITE_SUPABASE_URL=https://VOTRE_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Netlify (Site settings → Environment variables) ---
# Ajoute les MÊMES variables : VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
# Puis Supabase → Authentication → URL configuration :
#   Site URL = https://<ton-site>.netlify.app
#   Redirect URLs = https://<ton-site>.netlify.app/**  (et localhost pour le dev)
