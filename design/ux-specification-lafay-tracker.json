{
  "meta": {
    "titre": "Lafay Tracker — Spécification UX & design system (mobile-first)",
    "version": "1.0.0",
    "cible_device_reference": "iPhone 12 et suivants (390×844 pt logiques, encoche / Dynamic Island, safe areas)",
    "priorite_visuelle": "mode_sombre",
    "principes_ux": [
      "Usage à une main : zone d’action basse, CTA principaux dans le tiers inférieur de l’écran",
      "Lisibilité sous effort : contraste élevé, hiérarchie typographique forte, peu de texte dense sur Séance et Timer",
      "Outil de terrain, pas tableau de bord SaaS : surfaces mates, une accentuation par écran, pas de illustrations stock",
      "Feedback immédiat : états chargement / succès / erreur courts et non intrusifs",
      "Navigation basse fixe (5+1 ou 6 slots) + accès Paramètres en coin supérieur droit"
    ]
  },
  "design_system": {
    "philosophie": "Sobre, sportif, compact, premium — typographie géométrique humaniste + chiffres monospaces pour reps et temps.",
    "couleurs": {
      "fond_niveaux": {
        "canvas": "#050506",
        "surface_0": "#0B0B0D",
        "surface_1": "#121214",
        "surface_2": "#1A1A1E",
        "surface_elevated": "#222228"
      },
      "texte": {
        "primary": "#F2F1EC",
        "secondary": "#A9A8A0",
        "muted": "#6E6E76",
        "inverse_sur_accent": "#0A0A0A"
      },
      "accent": {
        "primary": "#D8FF3C",
        "primary_hover": "#E6FF6A",
        "primary_muted": "rgba(216,255,60,0.14)",
        "ring_focus": "rgba(216,255,60,0.45)"
      },
      "semantique": {
        "success": "#3FD98A",
        "warning": "#FFB547",
        "danger": "#FF5C5C",
        "info": "#5CB8FF"
      },
      "bordures": {
        "subtle": "rgba(255,255,255,0.06)",
        "default": "rgba(255,255,255,0.10)",
        "strong": "rgba(255,255,255,0.16)"
      }
    },
    "typographie": {
      "familles": {
        "ui": "Inter, SF Pro Text, system-ui, sans-serif",
        "chiffres": "SF Mono, ui-monospace, Menlo, monospace"
      },
      "echelles_rem": {
        "display_timer": "4.25rem",
        "titre_ecran": "1.375rem",
        "sous_titre": "0.9375rem",
        "corps": "0.9375rem",
        "caption": "0.75rem",
        "overline": "0.625rem"
      },
      "regles_effort": [
        "Sur Séance et Timer : corps ≥ 15px, ratio de contraste ≥ 7:1 sur texte critique",
        "Chiffres (reps, secondes) toujours en monospace, tracking légèrement resserré"
      ]
    },
    "espacements": {
      "unite_base_px": 4,
      "gouttiere_ecran": 16,
      "section_gap": 20,
      "carte_padding": 16,
      "entre_cta_verticaux": 12
    },
    "rayons": {
      "chip": 10,
      "bouton": 14,
      "carte": 18,
      "sheet": 22,
      "plein_ecran_modal": 0
    },
    "elevation": {
      "nav_bar": "0 -4px 24px rgba(0,0,0,0.45)",
      "carte": "0 1px 0 rgba(255,255,255,0.04) inset"
    },
    "zones_tactiles": {
      "minimum_pt": 48,
      "cta_principal_hauteur_min_px": 56,
      "hit_slop_px": 8
    },
    "motion": {
      "duree_courte_ms": 120,
      "duree_standard_ms": 200,
      "courbe": "cubic-bezier(0.2, 0.9, 0.2, 1)",
      "reduced_motion": "respecter prefers-reduced-motion pour anneau timer et transitions"
    },
    "iconographie": {
      "style": "Ligne 2px, coins légèrement arrondis, pas d’emoji comme seule icône de navigation",
      "note": "Réserver pictos simples (play, horloge, liste, graph) — emoji optionnel uniquement en décoration secondaire"
    }
  },
  "navigation": {
    "modele": "bottom_navigation_principale + stack_modal_pour_timer + routes_secondaires",
    "structure_recommandee": {
      "next_app_router": {
        "groupe_auth": "(auth)/login, (auth)/register",
        "groupe_app": "(app)/layout avec BottomNav",
        "routes": [
          { "path": "/", "ecran": "Accueil", "fichier": "app/(app)/page.tsx" },
          { "path": "/programs", "ecran": "Liste des programmes", "fichier": "app/(app)/programs/page.tsx" },
          { "path": "/session/[workoutId]", "ecran": "Séance en cours", "fichier": "app/(app)/session/[workoutId]/page.tsx" },
          { "path": "/session/[workoutId]/timer", "ecran": "Timer plein écran", "fichier": "app/(app)/session/[workoutId]/timer/page.tsx" },
          { "path": "/session/[workoutId]/complete", "ecran": "Fin de séance", "fichier": "app/(app)/session/[workoutId]/complete/page.tsx" },
          { "path": "/journal", "ecran": "Journal", "fichier": "app/(app)/journal/page.tsx" },
          { "path": "/history", "ecran": "Historique", "fichier": "app/(app)/history/page.tsx" },
          { "path": "/stats", "ecran": "Statistiques", "fichier": "app/(app)/stats/page.tsx" },
          { "path": "/settings", "ecran": "Paramètres", "fichier": "app/(app)/settings/page.tsx" }
        ]
      },
      "react_spa_equivalent": {
        "fichier_routes": "src/App.tsx",
        "remarque": "Même arbre ; Timer en route dédiée ou overlay full viewport avec ?fullscreen=1"
      }
    },
    "bottom_nav": {
      "slots": [
        { "id": "home", "label": "Accueil", "route": "/", "icone": "home" },
        { "id": "programs", "label": "Programmes", "route": "/programs", "icone": "layers" },
        { "id": "journal", "label": "Journal", "route": "/journal", "icone": "notebook" },
        { "id": "history", "label": "Historique", "route": "/history", "icone": "clock" },
        { "id": "stats", "label": "Stats", "route": "/stats", "icone": "trending" }
      ],
      "hauteur_zone_px": 64,
      "safe_area": "padding-bottom: env(safe-area-inset-bottom)"
    },
    "header_contextuel": {
      "gauche": "Retour (flèche) ou fermeture selon stack",
      "centre": "Titre court (1 ligne, ellipses)",
      "droite": "Paramètres (engrenage) ou menu contextuel séance (⋯)"
    },
    "flows_cles": [
      {
        "nom": "Reprise rapide",
        "etapes": ["Accueil → carte « Reprendre » → Séance en cours (workout existant in_progress)"]
      },
      {
        "nom": "Nouvelle séance",
        "etapes": ["Accueil ou Programmes → choix gabarit → start RPC → /session/[id]"]
      },
      {
        "nom": "Repos",
        "etapes": ["Séance → Valider série → Timer plein écran (push) ou bottom sheet timer selon préférence ; presets 25–180s"]
      },
      {
        "nom": "Clôture",
        "etapes": ["Dernière série validée ou bouton Terminer → Fin de séance (RPE + journal) → Historique mis à jour"]
      }
    ]
  },
  "bibliotheque_composants": {
    "description": "Découpage React ; préfixe `Lf` (Lafay) pour éviter collisions. Préférer composition légère plutôt que gros monolithes.",
    "composants": [
      {
        "nom": "LfAppShell",
        "role": "Layout colonne : SafeAreaTop, scroll main, BottomNav, toaster",
        "fichiers_suggeres": ["components/layout/LfAppShell.tsx"],
        "props": ["children", "bottomNavSlot", "headerSlot?"]
      },
      {
        "nom": "LfScreenHeader",
        "role": "Titre + actions ; hauteur fixe 48–56px",
        "fichiers_suggeres": ["components/layout/LfScreenHeader.tsx"],
        "props": ["title", "onBack?", "rightAction?"]
      },
      {
        "nom": "LfBottomNav",
        "role": "5 onglets + état actif ; hit area 48px min",
        "fichiers_suggeres": ["components/nav/LfBottomNav.tsx"],
        "props": ["items", "activeId", "onChange"]
      },
      {
        "nom": "LfPrimaryButton",
        "role": "CTA pleine largeur, 56px min, états loading/disabled",
        "fichiers_suggeres": ["components/ui/LfPrimaryButton.tsx"],
        "props": ["children", "onClick", "loading?", "variant?: primary | danger"]
      },
      {
        "nom": "LfSecondaryButton",
        "role": "Contour discret, même hauteur que primaire pour paires Passer / Valider",
        "fichiers_suggeres": ["components/ui/LfSecondaryButton.tsx"]
      },
      {
        "nom": "LfIconButton",
        "role": "48×48 zone tactile, fond surface_2",
        "fichiers_suggeres": ["components/ui/LfIconButton.tsx"],
        "props": ["icon", "ariaLabel", "onClick"]
      },
      {
        "nom": "LfCard",
        "role": "Surface avec bordure subtile ; pas d’ombre portée lourde",
        "fichiers_suggeres": ["components/ui/LfCard.tsx"],
        "props": ["children", "padding?", "onClick?"]
      },
      {
        "nom": "LfStatPill",
        "role": "Valeur grande + label overline (ex. séries / reps)",
        "fichiers_suggeres": ["components/data/LfStatPill.tsx"],
        "props": ["label", "value", "suffix?"]
      },
      {
        "nom": "LfExerciseBlock",
        "role": "Bloc exercice : nom, variante, grille séries",
        "fichiers_suggeres": ["components/session/LfExerciseBlock.tsx"],
        "props": ["exercise", "sets", "currentSetIndex", "onSetPress", "onValidateSet"]
      },
      {
        "nom": "LfSetChip",
        "role": "Une série : index, reps saisies ou « — », état done / current / idle",
        "fichiers_suggeres": ["components/session/LfSetChip.tsx"]
      },
      {
        "nom": "LfLastPerformanceBar",
        "role": "« Dernière fois » en monospace sur une ligne",
        "fichiers_suggeres": ["components/session/LfLastPerformanceBar.tsx"],
        "props": ["repsPerSet: number[]"]
      },
      {
        "nom": "LfRestTimerSheet",
        "role": "Sheet ou plein écran : anneau, presets, +10s, pause",
        "fichiers_suggeres": ["components/timer/LfRestTimerSheet.tsx", "components/timer/LfTimerRing.tsx"]
      },
      {
        "nom": "LfPresetChips",
        "role": "Rangée scrollable horizontalement si besoin : 25, 45, 60, 90, 120, 180 s",
        "fichiers_suggeres": ["components/timer/LfPresetChips.tsx"],
        "props": ["valuesSec", "activeSec", "onSelect"]
      },
      {
        "nom": "LfSegmentedControl",
        "role": "Filtres historique (7 jours, Mois, Exercice…)",
        "fichiers_suggeres": ["components/filters/LfSegmentedControl.tsx"]
      },
      {
        "nom": "LfJournalEntryForm",
        "role": "Champs ressenti, énergie, sommeil, douleur, note libre",
        "fichiers_suggeres": ["components/journal/LfJournalEntryForm.tsx"]
      },
      {
        "nom": "LfListRow",
        "role": "Ligne historique / journal : titre, méta, chevron ou RPE",
        "fichiers_suggeres": ["components/lists/LfListRow.tsx"]
      },
      {
        "nom": "LfEmptyState",
        "role": "Illustration minimale (trait géométrique) + 1 phrase + CTA",
        "fichiers_suggeres": ["components/feedback/LfEmptyState.tsx"]
      },
      {
        "nom": "LfToast",
        "role": "Retours courts (série enregistrée, erreur réseau)",
        "fichiers_suggeres": ["components/feedback/LfToast.tsx"]
      },
      {
        "nom": "LfBottomSheet",
        "role": "Panneau modal bas (journal, confirmations légères)",
        "fichiers_suggeres": ["components/overlays/LfBottomSheet.tsx"]
      },
      {
        "nom": "LfSwitch",
        "role": "Interrupteur Paramètres (son, vibration)",
        "fichiers_suggeres": ["components/ui/LfSwitch.tsx"]
      },
      {
        "nom": "LfChartBars",
        "role": "Graphique barres minimal pour Stats (sans lib chart lourde en V1)",
        "fichiers_suggeres": ["components/charts/LfChartBars.tsx"]
      }
    ]
  },
  "ecrans": [
    {
