  "donnees_journal_post_seance": {
    "champs": [
      { "id": "mood", "type": "echelle_1_5", "label": "Ressenti" },
      { "id": "energy", "type": "echelle_1_5", "label": "Énergie" },
      { "id": "sleep_quality", "type": "echelle_1_5", "label": "Sommeil" },
      { "id": "pain", "type": "echelle_0_5", "label": "Douleur" },
      { "id": "note", "type": "texte_court", "max_length": 500, "label": "Note libre" }
    ],
    "remarque_implementation": "À mapper sur table dédiée (ex. session_journal) liée à workouts.id ; non présente dans les migrations actuelles — extension schéma recommandée."
  },
  "accessibilite": {
    "wcag_cible": "AA minimum sur textes ; objectif AAA sur écrans effort pour contraste",
    "focus": "Anneau focus visible (accent ring) sur boutons et presets",
    "tailles_dynamiques": "Respecter text-size préférences OS si possible (rem + clamp)"
